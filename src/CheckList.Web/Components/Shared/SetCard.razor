<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title">@Set.SetName</h5>
        <p class="card-text text-muted small">@Set.SetDscr</p>
    </div>
    <div class="card-footer d-flex gap-2">
        <a href="sets/@Set.Id" class="btn btn-sm btn-primary">Open</a>
        <button class="btn btn-sm btn-outline-danger ms-auto" @onclick="() => OnDelete.InvokeAsync(Set.Id)">Delete</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public CheckSetDto Set { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<int> OnDelete { get; set; }
}
