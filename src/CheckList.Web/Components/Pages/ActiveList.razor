@page "/sets/{SetId:int}/lists/{ListId:int}"
@attribute [Authorize]
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject ICheckCategoryRepository CategoryRepo
@inject ICheckActionRepository ActionRepo
@inject ICheckListRepository ListRepo
@inject AuthenticationStateProvider AuthStateProvider
@inject IHubContext<CheckListHub, ICheckListHubClient> HubContext
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Active List</PageTitle>

<div class="container-fluid">
    <h2>@(string.IsNullOrEmpty(_listName) ? "Loading…" : _listName)</h2>

    @if (_categories is null)
    {
        <p>Loading checklist items…</p>
    }
    else if (!_categories.Any())
    {
        <p class="text-muted">No items found for this list.</p>
    }
    else
    {
        @foreach (var cat in _categories)
        {
            <div class="category-section mb-3">
                <h5 class="category-header">@cat.CategoryText</h5>
                @foreach (var action in cat.Actions)
                {
                    <CheckActionItem Action="action" OnToggle="ToggleAction" />
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public int SetId { get; set; }
    [Parameter] public int ListId { get; set; }

    private string? _listName;
    private List<CheckCategoryDto>? _categories;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        // Load list name and categories directly from repositories
        var list = await ListRepo.GetByIdAsync(ListId);
        _listName = list?.ListName;

        var cats = await CategoryRepo.GetByListAsync(ListId);
        _categories = [];
        foreach (var cat in cats)
        {
            var actions = await ActionRepo.GetByCategoryAsync(cat.Id) ?? [];
            _categories.Add(new CheckCategoryDto(
                cat.Id, cat.ListId, cat.CategoryText, cat.CategoryDscr, cat.SortOrder,
                actions.Select(a => new CheckActionDto(
                    a.Id, a.CategoryId, a.ListId, a.SetId,
                    a.ActionText, a.ActionDscr,
                    a.CompleteInd, a.CompletedBy, a.CompletedAt, a.SortOrder)).ToList()));
        }

        // SignalR hub is in the same app — use origin directly
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/checklist"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<ActionUpdateDto>("ReceiveActionUpdate", update =>
        {
            if (_categories is null) return;

            foreach (var cat in _categories)
            {
                var idx = cat.Actions.IndexOf(cat.Actions.FirstOrDefault(a => a.Id == update.ActionId)!);
                if (idx >= 0)
                {
                    cat.Actions[idx] = cat.Actions[idx] with
                    {
                        CompleteInd = update.CompleteInd,
                        CompletedBy = update.CompletedBy,
                        CompletedAt = update.CompletedAt
                    };
                    InvokeAsync(StateHasChanged);
                    break;
                }
            }
        });

        await _hubConnection.StartAsync();
        await _hubConnection.SendAsync("JoinSet", SetId.ToString());
    }

    private async Task ToggleAction(int actionId)
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.Identity?.Name ?? string.Empty;
        var action = await ActionRepo.ToggleCompleteAsync(actionId, userId);
        if (action is null) return;
        var update = new ActionUpdateDto(action.SetId, action.ListId, action.Id, action.CompleteInd, action.CompletedBy, action.CompletedAt);
        await HubContext.Clients.Group($"set-{update.SetId}").ReceiveActionUpdate(update);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.SendAsync("LeaveSet", SetId.ToString());
            await _hubConnection.DisposeAsync();
        }
    }
}
